<div id="modal-developer" class="modal fade">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-cog"></i> {{ heading_title }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="alert-modal"></div>
        <ul class="nav nav-tabs">
          <li class="nav-item"><a href="#tab-general" data-bs-toggle="tab" class="nav-link active">{{ tab_general }}</a></li>
          <li class="nav-item"><a href="#tab-data" data-bs-toggle="tab" class="nav-link">{{ tab_data }}</a></li>
        </ul>
        <div class="tab-content">
          <div id="tab-general" class="tab-pane active">
            <fieldset>
              <legend>Static Site Rendering</legend>
              <table class="table table-bordered mt-3">
                <thead>
                  <tr>
                    <th>{{ column_store }}</th>
                    <th class="text-end">{{ column_action }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for store in stores %}
                    <tr>
                      <td>{{ store.name }}</td>
                      <td class="text-end">




                          <button type="button" value="{{ store.store_id }}" title="{{ text_rebuild }}" class="btn btn-warning"><i class="fa-solid fa-store"></i></button>

                        <button type="button" value="{{ store.store_id }}" title="{{ text_template }}" class="btn btn-danger"><i class="fa-solid fa-code"></i></button>

                        <button type="button" value="{{ store.store_id }}" title="{{ text_sass }}" class="btn btn-danger"><i class="fa-brands fa-sass"></i></button>

                        <button type="button" value="{{ store.store_id }}" title="{{ text_clear }}" class="btn btn-danger"><i class="fa-solid fa-trash-can"></i></button>


                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </fieldset>
          </div>
          <div id="tab-data" class="tab-pane">
            <fieldset>
              <legend>Local Storage</legend>
              <table class="table table-bordered">
                <tbody>
                  <tr>
                    <td>{{ text_cache }}
                      <br/>
                      <span class="fw-light">{{ help_cache }}</span></td>
                    <td class="text-end"><button type="button" value="cache" title="{{ button_clear }}" class="btn btn-warning"><i class="fa-solid fa-rotate"></i></button></td>
                  </tr>
                  <tr>
                    <td>{{ text_vendor }}
                      <br/>
                      <span class="fw-light">{{ help_vendor }}</span></td>
                    <td class="text-end"><button type="button" value="vendor" title="{{ button_clear }}" class="btn btn-warning"><i class="fa-solid fa-rotate"></i></button></td>
                  </tr>
                </tbody>
              </table>
            </fieldset>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
